#: ../../library/os.path.rst:2
msgid ":mod:`!os.path` --- Common pathname manipulations"
msgstr ""

#: ../../library/os.path.rst:7
msgid ""
"**Source code:** :source:`Lib/genericpath.py`, :source:`Lib/posixpath.py` "
"(for POSIX) and :source:`Lib/ntpath.py` (for Windows)."
msgstr ""

#: ../../library/os.path.rst:14
msgid ""
"This module implements some useful functions on pathnames. To read or write "
"files see :func:`open`, and for accessing the filesystem see the :mod:`os` "
"module. The path parameters can be passed as strings, or bytes, or any "
"object implementing the :class:`os.PathLike` protocol."
msgstr ""
"–¶–µ–є –Љ–Њ–і—Г–ї—М —А–µ–∞–ї—Ц–Ј—Г—Ф –і–µ—П–Ї—Ц –Ї–Њ—А–Є—Б–љ—Ц —Д—Г–љ–Ї—Ж—Ц—Ч –і–ї—П —И–ї—П—Е—Ц–≤. –©–Њ–± –њ—А–Њ—З–Є—В–∞—В–Є –∞–±–Њ "
"–Ј–∞–њ–Є—Б–∞—В–Є —Д–∞–є–ї–Є, –њ–µ—А–µ–≥–ї—П–љ—М—В–µ :func:`open`, –∞ –і–ї—П –і–Њ—Б—В—Г–њ—Г –і–Њ —Д–∞–є–ї–Њ–≤–Њ—Ч —Б–Є—Б—В–µ–Љ–Є "
"–њ–µ—А–µ–≥–ї—П–љ—М—В–µ –Љ–Њ–і—Г–ї—М :mod:`os`. –Я–∞—А–∞–Љ–µ—В—А–Є —И–ї—П—Е—Г –Љ–Њ–ґ–љ–∞ –њ–µ—А–µ–і–∞—В–Є —П–Ї —А—П–і–Ї–Є, –∞–±–Њ "
"–±–∞–є—В–Є, –∞–±–Њ –±—Г–і—М-—П–Ї–Є–є –Њ–±вАЩ—Ф–Ї—В, —Й–Њ —А–µ–∞–ї—Ц–Ј—Г—Ф –њ—А–Њ—В–Њ–Ї–Њ–ї :class:`os.PathLike`."

#: ../../library/os.path.rst:19
msgid ""
"Unlike a Unix shell, Python does not do any *automatic* path expansions. "
"Functions such as :func:`expanduser` and :func:`expandvars` can be invoked "
"explicitly when an application desires shell-like path expansion.  (See also"
" the :mod:`glob` module.)"
msgstr ""

#: ../../library/os.path.rst:26
msgid "The :mod:`pathlib` module offers high-level path objects."
msgstr "–Ь–Њ–і—Г–ї—М :mod:`pathlib` –њ—А–Њ–њ–Њ–љ—Г—Ф –Њ–±вАЩ—Ф–Ї—В–Є —И–ї—П—Е—Г –≤–Є—Б–Њ–Ї–Њ–≥–Њ —А—Ц–≤–љ—П."

#: ../../library/os.path.rst:31
msgid ""
"All of these functions accept either only bytes or only string objects as "
"their parameters.  The result is an object of the same type, if a path or "
"file name is returned."
msgstr ""
"–£—Б—Ц —Ж—Ц —Д—Г–љ–Ї—Ж—Ц—Ч –њ—А–Є–є–Љ–∞—О—В—М —П–Ї –њ–∞—А–∞–Љ–µ—В—А–Є –ї–Є—И–µ –±–∞–є—В–Є –∞–±–Њ –ї–Є—И–µ —А—П–і–Ї–Њ–≤—Ц –Њ–±вАЩ—Ф–Ї—В–Є. "
"–†–µ–Ј—Г–ї—М—В–∞—В–Њ–Љ —Ф –Њ–±вАЩ—Ф–Ї—В —В–Њ–≥–Њ —Б–∞–Љ–Њ–≥–Њ —В–Є–њ—Г, —П–Ї—Й–Њ –њ–Њ–≤–µ—А—В–∞—Ф—В—М—Б—П —И–ї—П—Е –∞–±–Њ —Ц–ЉвАЩ—П "
"—Д–∞–є–ї—Г."

#: ../../library/os.path.rst:37
msgid ""
"Since different operating systems have different path name conventions, "
"there are several versions of this module in the standard library.  The "
":mod:`os.path` module is always the path module suitable for the operating "
"system Python is running on, and therefore usable for local paths.  However,"
" you can also import and use the individual modules if you want to "
"manipulate a path that is *always* in one of the different formats.  They "
"all have the same interface:"
msgstr ""
"–Ю—Б–Ї—Ц–ї—М–Ї–Є —А—Ц–Ј–љ—Ц –Њ–њ–µ—А–∞—Ж—Ц–є–љ—Ц —Б–Є—Б—В–µ–Љ–Є –Љ–∞—О—В—М —А—Ц–Ј–љ—Ц —Ц–Љ–µ–љ–∞ —И–ї—П—Е—Ц–≤, —Г —Б—В–∞–љ–і–∞—А—В–љ—Ц–є "
"–±—Ц–±–ї—Ц–Њ—В–µ—Ж—Ц —Ф –Ї—Ц–ї—М–Ї–∞ –≤–µ—А—Б—Ц–є —Ж—М–Њ–≥–Њ –Љ–Њ–і—Г–ї—П. –Ь–Њ–і—Г–ї—М :mod:`os.path` –Ј–∞–≤–ґ–і–Є —Ф "
"–Љ–Њ–і—Г–ї–µ–Љ —И–ї—П—Е—Г, —П–Ї–Є–є –њ—Ц–і—Е–Њ–і–Є—В—М –і–ї—П –Њ–њ–µ—А–∞—Ж—Ц–є–љ–Њ—Ч —Б–Є—Б—В–µ–Љ–Є, —Г —П–Ї—Ц–є –њ—А–∞—Ж—О—Ф Python,"
" —Ц —В–Њ–Љ—Г –є–Њ–≥–Њ –Љ–Њ–ґ–љ–∞ –≤–Є–Ї–Њ—А–Є—Б—В–Њ–≤—Г–≤–∞—В–Є –і–ї—П –ї–Њ–Ї–∞–ї—М–љ–Є—Е —И–ї—П—Е—Ц–≤. –Ю–і–љ–∞–Ї –≤–Є —В–∞–Ї–Њ–ґ "
"–Љ–Њ–ґ–µ—В–µ —Ц–Љ–њ–Њ—А—В—Г–≤–∞—В–Є —В–∞ –≤–Є–Ї–Њ—А–Є—Б—В–Њ–≤—Г–≤–∞—В–Є –Њ–Ї—А–µ–Љ—Ц –Љ–Њ–і—Г–ї—Ц, —П–Ї—Й–Њ —Е–Њ—З–µ—В–µ "
"–Љ–∞–љ—Ц–њ—Г–ї—О–≤–∞—В–Є —И–ї—П—Е–Њ–Љ, —П–Ї–Є–є *–Ј–∞–≤–ґ–і–Є* –Љ–∞—Ф –Њ–і–Є–љ —Ц–Ј —А—Ц–Ј–љ–Є—Е —Д–Њ—А–Љ–∞—В—Ц–≤. –£—Б—Ц –≤–Њ–љ–Є "
"–Љ–∞—О—В—М –Њ–і–љ–∞–Ї–Њ–≤–Є–є —Ц–љ—В–µ—А—Д–µ–є—Б:"

#: ../../library/os.path.rst:45
msgid ":mod:`posixpath` for UNIX-style paths"
msgstr ":mod:`posixpath` –і–ї—П —И–ї—П—Е—Ц–≤ —Г —Б—В–Є–ї—Ц UNIX"

#: ../../library/os.path.rst:46
msgid ":mod:`ntpath` for Windows paths"
msgstr ":mod:`ntpath` –і–ї—П —И–ї—П—Е—Ц–≤ Windows"

#: ../../library/os.path.rst:51
msgid ""
":func:`exists`, :func:`lexists`, :func:`isdir`, :func:`isfile`, "
":func:`islink`, and :func:`ismount` now return ``False`` instead of raising "
"an exception for paths that contain characters or bytes unrepresentable at "
"the OS level."
msgstr ""
":func:`exists`, :func:`lexists`, :func:`isdir`, :func:`isfile`, "
":func:`islink` —Ц :func:`ismount` —В–µ–њ–µ—А –Ј–∞–Љ—Ц—Б—В—М —Ж—М–Њ–≥–Њ –њ–Њ–≤–µ—А—В–∞—О—В—М ``False`` "
"—Б—В–≤–Њ—А–µ–љ–љ—П –≤–Є–љ—П—В–Ї—Г –і–ї—П —И–ї—П—Е—Ц–≤, —П–Ї—Ц –Љ—Ц—Б—В—П—В—М —Б–Є–Љ–≤–Њ–ї–Є –∞–±–Њ –±–∞–є—В–Є, —П–Ї—Ц –љ–µ–Љ–Њ–ґ–ї–Є–≤–Њ "
"–≤—Ц–і–Њ–±—А–∞–Ј–Є—В–Є –љ–∞ —А—Ц–≤–љ—Ц –Ю–°."

#: ../../library/os.path.rst:59
msgid ""
"Return a normalized absolutized version of the pathname *path*. On most "
"platforms, this is equivalent to calling the function :func:`normpath` as "
"follows: ``normpath(join(os.getcwd(), path))``."
msgstr ""
"–Я–Њ–≤–µ—А—В–∞—Ф –љ–Њ—А–Љ–∞–ї—Ц–Ј–Њ–≤–∞–љ—Г –∞–±—Б–Њ–ї—О—В–Є–Ј–Њ–≤–∞–љ—Г –≤–µ—А—Б—Ц—О —Ц–Љ–µ–љ—Ц —И–ї—П—Е—Г *path*. –Э–∞ "
"–±—Ц–ї—М—И–Њ—Б—В—Ц –њ–ї–∞—В—Д–Њ—А–Љ —Ж–µ –µ–Ї–≤—Ц–≤–∞–ї–µ–љ—В–љ–Њ –≤–Є–Ї–ї–Є–Ї—Г —Д—Г–љ–Ї—Ж—Ц—Ч :func:`normpath` —В–∞–Ї–Є–Љ "
"—З–Є–љ–Њ–Љ: ``normpath(join(os.getcwd(), path))``."

